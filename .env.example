# Testlab AI Agents Configuration
# Copy this file to .env and fill in your values

# REQUIRED: Anthropic API Key
ANTHROPIC_API_KEY=your_api_key_here

# Prometheus Configuration
PROMETHEUS_URL=http://your-prometheus-host:9090

# Webhook for notifications (Discord/Slack/etc)
# Discord webhook: https://discord.com/api/webhooks/...
# Slack webhook: https://hooks.slack.com/services/...
WEBHOOK_URL=

# Monitoring Agent Settings
MONITOR_INTERVAL=300  # Seconds between monitoring cycles (default: 5 minutes)

# Proxmox API (Optional - for cluster-specific monitoring)
PROXMOX_URL=https://your-proxmox-host:8006
PROXMOX_TOKEN_ID=user@pam!tokenid
PROXMOX_TOKEN_SECRET=your-token-secret

# Remediation Agent Settings
DRY_RUN=true  # Set to 'false' to enable actual remediation actions
APPROVED_ACTIONS=send_alert  # Comma-separated list: restart_container,clean_disk_space,send_alert,scale_resources
# Use '*' to approve all actions (not recommended for production)

# Network Configuration
# If running on Proxmox, you may need to adjust these
# PROMETHEUS_URL=http://<LAN_IP_REDACTED>:9090  # Direct IP if DNS doesn't work
